# Root workspace variables only.
TURBO_TELEMETRY_DISABLED=1

# Local-only audio conversion defaults. apps/api/.env.example is the app source of truth.
LOCAL_AUDIO_CACHE_ROOT=.local/audio/cache
LOCAL_AUDIO_TEMP_ROOT=.local/audio/tmp
LOCAL_AUDIO_STAGING_ROOT=.local/audio/staging
LOCAL_AUDIO_STAGING_TTL_HOURS=24
LOCAL_AUDIO_TEMP_TTL_HOURS=2
LOCAL_AUDIO_MAX_DURATION_SEC=7200
LOCAL_AUDIO_MAX_SOURCE_BYTES=1073741824
LOCAL_AUDIO_MAX_OUTPUT_BYTES=536870912
LOCAL_AUDIO_WORKER_ENABLED=true
LOCAL_AUDIO_WORKER_CONCURRENCY=1
FFMPEG_PATH=ffmpeg
YT_DLP_PATH=yt-dlp
