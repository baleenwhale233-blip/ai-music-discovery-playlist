{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "alpha:preflight-before-dev",
      "type": "shell",
      "command": "pnpm preflight:alpha -- --require-free-dev-ports",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "alpha:preflight",
      "type": "shell",
      "command": "pnpm preflight:alpha",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "alpha:verify-web",
      "type": "shell",
      "command": "pnpm verify:alpha-web",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "api:build",
      "type": "shell",
      "command": "pnpm --filter @ai-music-playlist/api build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "api:typecheck",
      "type": "shell",
      "command": "pnpm --filter @ai-music-playlist/api typecheck",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "api:test",
      "type": "shell",
      "command": "pnpm --filter @ai-music-playlist/api test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "api:test-local-audio-lifecycle",
      "type": "shell",
      "command": "pnpm --filter @ai-music-playlist/api test -- src/modules/contents/local-audio-lifecycle.test.ts",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "admin:dev",
      "type": "shell",
      "command": "pnpm --filter @ai-music-playlist/admin dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "next dev",
          "endsPattern": "Ready in"
        }
      }
    }
  ]
}
