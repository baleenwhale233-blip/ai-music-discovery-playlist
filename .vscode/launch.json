{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:api",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Web Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:web",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Admin Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @ai-music-playlist/admin dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Local Audio Clean Room",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:local-audio-clean",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Alpha Web (Dev)",
      "stopAll": true,
      "preLaunchTask": "alpha:preflight-before-dev",
      "configurations": ["API Dev", "Web Dev"]
    },
    {
      "name": "Local Audio Experiment (Dev)",
      "stopAll": true,
      "preLaunchTask": "stop-local-audio-experiment",
      "configurations": ["API Dev", "Admin Dev"]
    }
  ]
}
