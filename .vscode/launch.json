{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @ai-music-playlist/api dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Admin Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @ai-music-playlist/admin dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Local Audio Clean Room",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev:local-audio-clean",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Local Audio Experiment (Dev)",
      "stopAll": true,
      "preLaunchTask": "stop-local-audio-experiment",
      "configurations": [
        "API Dev",
        "Admin Dev"
      ]
    }
  ]
}
