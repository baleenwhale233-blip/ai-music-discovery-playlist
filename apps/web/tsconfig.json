{
  "extends": "../../packages/config/tsconfig.react.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@ai-music-playlist/types": [
        "../../packages/types/src"
      ],
      "@ai-music-playlist/api-contract": [
        "../../packages/api-contract/src"
      ],
      "@ai-music-playlist/config": [
        "../../packages/config/src"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
