NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_music_playlist
REDIS_URL=redis://localhost:6379

# Development defaults only. Production must override these with non-default secret values.
JWT_SECRET=change-me
SMS_PROVIDER=placeholder
ALPHA_LOGIN_CODE=246810
ALPHA_INVITE_CODE=alpha-50
ACCESS_TOKEN_EXPIRES_IN_SECONDS=604800
LOCAL_AUDIO_CACHE_DIR=.local-audio-cache
LOCAL_AUDIO_CACHE_ROOT=.local/audio/cache
LOCAL_AUDIO_TEMP_ROOT=.local/audio/tmp
LOCAL_AUDIO_STAGING_ROOT=.local/audio/staging
LOCAL_AUDIO_STAGING_TTL_HOURS=24
LOCAL_AUDIO_TEMP_TTL_HOURS=2
LOCAL_AUDIO_MAX_DURATION_SEC=7200
LOCAL_AUDIO_MAX_SOURCE_BYTES=1073741824
LOCAL_AUDIO_MAX_OUTPUT_BYTES=536870912
LOCAL_AUDIO_WORKER_ENABLED=true
LOCAL_AUDIO_WORKER_CONCURRENCY=1
FFMPEG_PATH=ffmpeg
YT_DLP_PATH=yt-dlp

# Development may omit this for permissive local CORS. Production must provide a comma-separated whitelist.
CORS_ALLOWED_ORIGINS=

# Development defaults to true. Production defaults to false unless explicitly enabled.
ENABLE_EXPERIMENTAL_ROUTES=
ENABLE_DEBUG_ROUTES=
