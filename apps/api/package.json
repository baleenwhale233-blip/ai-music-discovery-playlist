{
  "name": "@ai-music-playlist/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@ai-music-playlist/api-contract": "workspace:*",
    "@ai-music-playlist/config": "workspace:*",
    "@ai-music-playlist/types": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-express": "^10.4.7",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.21.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2"
  }
}
